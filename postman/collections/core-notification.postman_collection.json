    {
      "name": "06_Local_only_NonFunctional",
      "item": [
        {
          "name": "POST /internal/notifications - Latency test",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/internal/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["internal", "notifications"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"BROADCAST\",\n  \"eventId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babd\",\n  \"priority\": \"CRITICAL\",\n  \"timestamp\": \"2026-05-18T08:05:00Z\",\n  \"targetRole\": \"STUDENT\",\n  \"messageBody\": \"Latency test message\",\n  \"expiresAt\": \"2026-05-18T10:00:00Z\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'local') {",
                  "  pm.test('Local service responds under 1000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "  });",
                  "} else {",
                  "  pm.test('Skipped on mock', function () { pm.expect(true).to.eql(true); });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
