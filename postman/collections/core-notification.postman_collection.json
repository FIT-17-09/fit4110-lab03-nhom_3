              "path": ["internal", "notifications"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"USER_NOTICE\",\n  \"eventId\": \"00000000-0000-0000-0000-000000000003\",\n  \"priority\": \"HIGH\",\n  \"timestamp\": \"2026-05-18T08:00:00Z\",\n  \"userId\": \"SV-2026-001\",\n  \"channelType\": \"email\",\n  \"templateId\": \"TPL-01\",\n  \"scheduledAt\": \"2000-01-01T00:00:00Z\"\n}",
              "options": {"raw": {"language": "json"}}
