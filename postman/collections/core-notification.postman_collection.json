    {
      "name": "01_Functional",
      "item": [
        {
          "name": "POST /internal/notifications (UserNotice) - Send notification",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/internal/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["internal", "notifications"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"USER_NOTICE\",\n  \"eventId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\",\n  \"priority\": \"HIGH\",\n  \"timestamp\": \"2026-05-18T08:00:00Z\",\n  \"userId\": \"SV-2026-001\",\n  \"channelType\": \"email\",\n  \"templateId\": \"TPL-TUITION-FEE\",\n  \"scheduledAt\": null\n}",
              "options": {"raw": {"language": "json"}}
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Send notification accepted with 202', function () { pm.response.to.have.status(202); });",
                  "pm.test('Response has eventId', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('eventId');",
                  "  pm.variables.set('eventId', json.eventId);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /internal/notifications/{eventId}/status",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/internal/notifications/0196fb3d-4ad7-7d1e-9f49-5d5148d2babc/status",
              "host": ["{{baseUrl}}"],
              "path": ["internal", "notifications", "0196fb3d-4ad7-7d1e-9f49-5d5148d2babc", "status"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response contains status property', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        },
