          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Upstream user contact mock returns 200', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
